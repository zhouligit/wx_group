{
  "name": "@wx-group/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bash scripts/with-env.sh prisma generate && rm -rf dist tsconfig.tsbuildinfo && nest build",
    "postinstall": "prisma generate",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "dev:server": "nest start --watch",
    "start:prod": "bash ../scripts/start-api.sh",
    "prisma:generate": "bash scripts/with-env.sh prisma generate",
    "prisma:migrate": "bash scripts/with-env.sh prisma migrate dev",
    "prisma:deploy": "bash scripts/with-env.sh prisma migrate deploy",
    "prisma:push": "bash scripts/with-env.sh prisma db push",
    "prisma:seed": "bash scripts/with-env.sh ts-node prisma/seed.ts",
    "prisma:seed-groups": "bash scripts/with-env.sh ts-node prisma/seed-groups-only.ts",
    "prisma:pull": "bash scripts/with-env.sh prisma db pull"
  },
  "prisma": {
    "seed": "bash scripts/with-env.sh ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
