# ========== 应用 ==========
NODE_ENV=development
API_PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# 生产域名示例：
# CORS_ORIGIN=https://jiaoyou.yikuaikaixin.cn
# WEB_BASE_URL=https://jiaoyou.yikuaikaixin.cn

# ========== 数据库 ==========
DATABASE_URL=mysql://wxgroup:wxgroup123@localhost:3306/wx_group
# 远程库示例（无 CREATE DATABASE 权限时用 prisma db push，不要用 migrate dev）：
# DATABASE_URL=mysql://wx_group:密码@106.13.108.88:3306/wx_group_db

# ========== Redis ==========
REDIS_URL=redis://localhost:6379

# ========== 支付 ==========
# 测试阶段：所有订单实付 0.01 元（展示价不变）
PAYMENT_TEST_MODE=true
PAYMENT_TEST_AMOUNT=0.01
# 本地无微信商户时可 mock 支付
PAYMENT_USE_MOCK=true
# PAYMENT_USE_MOCK=false

# ========== 微信 ==========
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
# 商户 API 证书序列号（商户平台 → 账户中心 → API 安全）
WECHAT_SERIAL_NO=
# 商户私钥 apiclient_key.pem 内容（换行用 \n）或文件路径
WECHAT_PRIVATE_KEY=
# WECHAT_PRIVATE_KEY_PATH=/opt/wx_group/certs/apiclient_key.pem
WECHAT_NOTIFY_URL=http://localhost:3000/api/v1/payments/wechat/notify
# 生产：https://jiaoyou.yikuaikaixin.cn/api/v1/payments/wechat/notify

# ========== OSS（开发可留空） ==========
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=

# ========== 短信（开发 mock：验证码 123456） ==========
SMS_MOCK=true
SMS_ACCESS_KEY=
SMS_SIGN=
SMS_TEMPLATE_CODE=

# ========== 管理后台默认账号（seed） ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
